# Clerk (for JWT verification)
CLERK_SECRET_KEY=sk_live_...

# Sentry (error tracking)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Internal services (Railway private networking)
CLIENT_SERVICE_URL=http://client-service.railway.internal
CLIENT_SERVICE_API_KEY=your-client-service-api-key

# External services (public URLs, need API keys)
CONTENT_GENERATION_SERVICE_URL=https://content-generation.distribute.you
CONTENT_GENERATION_SERVICE_API_KEY=your-content-generation-service-api-key
BRAND_SERVICE_URL=https://brand.distribute.you
LEAD_SERVICE_URL=https://lead.distribute.you
KEY_SERVICE_URL=https://key.distribute.you
REPLY_QUALIFICATION_SERVICE_URL=https://reply-qualification.distribute.you
SCRAPING_SERVICE_URL=https://scraping.distribute.you
TRANSACTIONAL_EMAIL_SERVICE_URL=https://transactional-email.distribute.you
EMAIL_GATEWAY_SERVICE_URL=https://email-gateway.distribute.you

BILLING_SERVICE_URL=https://billing.distribute.you

# Service-to-service auth for external services
BILLING_SERVICE_API_KEY=your-billing-service-api-key
BRAND_SERVICE_API_KEY=your-brand-service-api-key
LEAD_SERVICE_API_KEY=your-lead-service-api-key
